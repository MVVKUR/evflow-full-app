# Template — copy to .env and fill in secrets. Safe to commit.

DATA_DIR=./data
RAW_DIR=./data/raw
PROCESSED_DIR=./data/processed
OUTPUT_DIR=./output
FIGURES_DIR=./output/figures

OCM_API_KEY=your_openchargemap_key_here
OCM_API_URL=https://api.openchargemap.io/v3/poi
OCM_COUNTRY_CODE=ID
OCM_MAX_RESULTS=5000

OVERPASS_API_URL=https://overpass-api.de/api/interpreter
GEOFABRIK_JAVA_PBF_URL=https://download.geofabrik.de/asia/indonesia/java-latest.osm.pbf
GEOFABRIK_JAVA_PBF_PATH=./data/raw/java-latest.osm.pbf

OSRM_BASE_URL=https://router.project-osrm.org
OSRM_PROFILE=driving

# Routing endpoint (/api/v1/route, Dijkstra). Build once with
# `python scripts/build_road_graph.py`, then the API loads this GraphML at runtime.
ROAD_GRAPH_PATH=./data/processed/jakarta_drive.graphml
ROUTING_DEFAULT_SPEED_KMH=40
# Range-aware nearest-station (Route & Battery): discount + reserve applied to the
# EV model's manufacturer range when deriving remaining range from current_soc.
ROUTING_RANGE_SAFETY_FACTOR=0.85
# EV model catalogue source (defaults to the committed ev_dataset.zip if unset).
EV_DATASET_CSV=./data/raw/indonesia_ev_specs_pricing_2026.csv

SPKLU_JAKARTA_PATH=./data/raw/spklu_jakarta.csv
BPS_JAKARTA_PATH=./data/raw/bps_jakarta_vehicles.csv

KAGGLE_USERNAME=
KAGGLE_KEY=
KAGGLE_DATASET=arsan5623/indonesia-electric-vehicle-ev-dataset-2026
KAGGLE_DATA_PATH=./data/raw/kaggle_indonesia_ev

JAKARTA_BBOX_SOUTH=-6.3760
JAKARTA_BBOX_WEST=106.6894
JAKARTA_BBOX_NORTH=-6.0890
JAKARTA_BBOX_EAST=106.9710
JAKARTA_CENTER_LAT=-6.2088
JAKARTA_CENTER_LON=106.8456

REQUEST_TIMEOUT_SECONDS=30
USER_AGENT=ev-charging-analysis-jakarta/0.1

# Xendit (payment). Backend uses the SECRET key; public key is frontend-only.
XENDIT_SECRET_KEY=your_xendit_development_secret_key
XENDIT_PUBLIC_KEY=your_xendit_development_public_key
XENDIT_BASE_URL=https://api.xendit.co
XENDIT_CALLBACK_TOKEN=set_a_webhook_verification_token

# Auth (JWT + Google OAuth)
JWT_SECRET=generate_a_long_random_secret
JWT_EXPIRE_MINUTES=10080
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://your-domain/api/v1/auth/google/callback
FRONTEND_URL=https://your-frontend
