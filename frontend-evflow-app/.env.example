# Frontend build-time environment. Copy to .env for local development.
# Safe to commit — no real secrets here (frontend values ship in the bundle).

# Which API the web bundle calls:
#   "/"       same-origin (nginx proxies /api/ to the backend) — used in prod
#   full URL  e.g. https://ev-flow-api.opensoft.id for a static-host build
VITE_EVFLOW_API_BASE_URL=/

# One-tap demo login password for the quick-access personas. NOT a secret — it
# ships in the bundle and the personas auto-register on the API. Set the same
# value the web build uses so the demo works across environments.
VITE_DEMO_PASSWORD=evflow-demo-2026

# Native (Expo) counterpart, only needed if you run the mobile app locally:
EXPO_PUBLIC_DEMO_PASSWORD=evflow-demo-2026
