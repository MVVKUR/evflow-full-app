{
  "name": "evflow-fullstack",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run backend:dev\" \"npm run frontend:web\"",
    "backend:dev": "cd backend-ev-flow && .venv/bin/python -m uvicorn api.main:app --reload --host 0.0.0.0 --port 8000",
    "backend:test": "cd backend-ev-flow && .venv/bin/python -m pytest -q",
    "frontend:install": "npm --prefix frontend-evflow-app install",
    "frontend:web": "npm --prefix frontend-evflow-app run web",
    "frontend:typecheck": "npm --prefix frontend-evflow-app run typecheck",
    "frontend:build": "npm --prefix frontend-evflow-app run build:web",
    "test": "npm run backend:test && npm run frontend:typecheck",
    "build": "npm run frontend:build"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
